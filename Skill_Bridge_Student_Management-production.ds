	reports
	{
		list placement_eligibility_Report
		{
			displayName = "All Placement Eligibilities"
			show all rows from placement_eligibility    
			(
				drive as "Drive"
				student as "Student"
				is_eligible as "Is Eligible"
				eligibility_reason as "Eligibility Reason"
			)
		}
		list certifications_Report
		{
			displayName = "All Certifications"
			show all rows from certifications    
			(
				student as "Student"
				certification_name as "Certification Name"
				platform as "Platform"
				domain as "Domain"
				completion_date as "Completion Date"
				certificate_upload as "Certificate Upload"
			)
		}
		kanban certifications_by_domain
		{
			displayName = "Domains"
			show all rows from certifications    
			(
				student as "Student"
				certification_name as "Certification Name"
				platform as "Platform"
				domain as "Domain"
				completion_date as "Completion Date"
				certificate_upload as "Certificate Upload"
			)
			options
			(
	 			display field = domain
	 		)
		}
		list student_profiles_Report
		{
			displayName = "All Student Profiles"
			show all rows from student_profiles    
			(
				student_id as "Student ID"
				student_name as "Student Name"
				register_number as "Register Number"
				department as "Department"
				year_1 as "Year"
				cgpa as "CGPA"
				technical_skills as "Technical Skills"
				soft_skills as "Soft Skills"
				resume_upload as "Resume Upload"
				linkedin_link as "LinkedIn Link"
				github_link as "GitHub Link"
			)
		}
		list placement_drives_Report
		{
			displayName = "All Placement Drives"
			show all rows from placement_drives    
			(
				drive_id as "Drive ID"
				company_name as "Company Name"
				eligibility_criteria as "Eligibility Criteria"
				package_offered as "Package Offered"
				(
					display = total,average,min,max	
				)
				drive_date as "Drive Date"
				eligible_students as "Eligible Students"
			)
		}
		list skill_analytics_Report
		{
			displayName = "All Skill Analytics"
			show all rows from skill_analytics    
			(
				department as "Department"
				skill_category as "Skill Category"
				student_count as "Student Count"
				avg_cgpa as "Average CGPA"
			)
		}
		list certification_summary_Report
		{
			displayName = "All Certification Summaries"
			show all rows from certification_summary    
			(
				student as "Student"
				certification_count as "Certification Count"
				total_certifications as "Total Certifications"
			)
		}
		list internship_applications_Report
		{
			displayName = "All Internship Applications"
			show all rows from internship_applications    
			(
				student as "Student"
				company_name as "Company Name"
				role as "Role"
				internship_type as "Internship Type"
				duration as "Duration"
				status as "Status"
				offer_letter as "Offer Letter"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Applied")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Selected")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Shortlisted")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban internship_applications_by_status
		{
			displayName = "Statuses"
			show all rows from internship_applications    
			(
				student as "Student"
				company_name as "Company Name"
				role as "Role"
				internship_type as "Internship Type"
				duration as "Duration"
				status as "Status"
				offer_letter as "Offer Letter"
			)
			options
			(
	 			display field = status
	 		)
		}
		list zoho_people_department_Report
		{
			displayName = "Zoho People Department Report"
			show all rows from people_department    
			(
				department_name as "Department Name"
				mail_alias as "Mail Alias"
			)
		}
	}
	pages
	{
		page DashBoard
