 application "Skill Bridge Student Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form certification_summary
		{
			displayname = "Certification Summary"
			success message = "Certification Summary Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			student
			(
				type = list	
				displayname = "Student"
				values  = student_profiles.ID
    			displayformat = [student_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			certification_count
			(
				type = number
				displayname = "Certification Count"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_certifications
			(
				type = number
				displayname = "Total Certifications"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form certifications
		{
			displayname = "Certifications"
			success message = "Certification Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			student
			(
				type = list	
				displayname = "Student"
				values  = student_profiles.ID
    			displayformat = [student_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			certification_name
			(
    			type = text
				displayname = "Certification Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			platform
			(
				type = picklist
				displayname = "Platform"
				values = {"FreeCodeCamp","Others","LinkedIn Learning","Microsoft Learn","EdX","Google Certifications","Udemy","Coursera"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			domain
			(
				type = picklist
				displayname = "Domain"
				values = {"Data Science","DevOps","Cloud Computing","Networking","UI/UX Design","Mobile Development","Artificial Intelligence","Database Management","Security","Web Development"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			completion_date
			(
    			type = date
				displayname = "Completion Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			certificate_upload
			(
    			type = url
				displayname = "Certificate Upload"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
