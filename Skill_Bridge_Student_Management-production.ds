				displayname = "Role"
	 			row = 1
	 			column = 1   
				width = medium
			)
			internship_type
			(
				type = radiobuttons
				displayname = "Internship Type"
				values = {"Offline","Online"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			duration
			(
    			type = text
				displayname = "Duration"
	 			row = 1
	 			column = 1   
				width = medium
			)
			status
			(
				type = picklist
				displayname = "Status"
				values = {"Shortlisted","Selected","Rejected","Applied"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			offer_letter
			(
    			type = url
				displayname = "Offer Letter"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Application Submitted","Application Reviewed","Application Rejected","Interview Scheduled","Application On Hold","Interview Conducted","Interview Rescheduled","Offer Extended","Offer Accepted","Offer Declined","Offer Revised","Onboarding Initiated","Offer Withdrawn","Internship Started","Onboarding Delayed","Internship In Progress","Internship Terminated","Internship Completed","Internship Extended","Final Evaluation Submitted","Internship Closed"}
			}
		}
